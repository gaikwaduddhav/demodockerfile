pipeline {
    agent any

    stages {

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t myapp:v1 .'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker rm -f myapp-container || true
                docker run -d \
                --name myapp-container \
                -p 8080:80 \
                myapp:v1
                '''
            }
        }

    }
}
